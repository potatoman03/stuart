{
  "name": "@stuart/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "node --env-file-if-exists=../../.env --import tsx --watch src/main.ts",
    "dev:electron": "node --env-file-if-exists=../../.env --import tsx src/dev.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "electron": "^37.4.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "^5.9.3"
  }
}
