{
  "name": "@stuart/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Stuart desktop study companion",
  "author": "Jonathan Chng",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "node --env-file-if-exists=../../.env --import tsx --watch src/main.ts",
    "dev:electron": "node --env-file-if-exists=../../.env --import tsx src/dev.ts",
    "build": "tsc -p tsconfig.json && node ../../scripts/build-desktop-assets.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "package:dir": "node ./scripts/package-desktop.mjs dir",
    "package:mac": "node ./scripts/package-desktop.mjs mac"
  },
  "dependencies": {
    "@stuart/harness": "workspace:*",
    "cors": "^2.8.5",
    "esbuild": "^0.25.0",
    "express": "^4.21.2",
    "mammoth": "^1.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@stuart/codex-runtime-darwin-arm64": "npm:@openai/codex@0.116.0-darwin-arm64",
    "@stuart/codex-runtime-darwin-x64": "npm:@openai/codex@0.116.0-darwin-x64",
    "@stuart/codex-runtime-linux-arm64": "npm:@openai/codex@0.116.0-linux-arm64",
    "@stuart/codex-runtime-linux-x64": "npm:@openai/codex@0.116.0-linux-x64",
    "@stuart/codex-runtime-win32-arm64": "npm:@openai/codex@0.116.0-win32-arm64",
    "@stuart/codex-runtime-win32-x64": "npm:@openai/codex@0.116.0-win32-x64"
  }
}
